        />

        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

        <style is:global>
            :root {
                /* Kanagawa Palette */
                --color-bg: #1f1f28; /* Sumi Ink */
                --color-sidebar: #16161d; /* Darker Ink */
                --color-sidebar-text: #dcd7ba; /* Old White */
                --color-sidebar-muted: #727169; /* Comment Grey */
                --color-accent: #7e9cd8; /* Crystal Blue */
                --color-link: #7e9cd8;
                --color-link-hover: #7fb4ca; /* Spring Blue */
                --color-text: #dcd7ba;
                --color-heading: #e6c384; /* Carp Yellow / Gold */
                --color-border: #2d4f67; /* Wave Blue */
                --color-card-bg: rgba(
                    34,
                    50,
