               Kanagawa Wave  —  fixed theme
               ═══════════════════════════════════════════════════ */
      :root {
        --color-bg: #1f1f28;
        --color-sidebar: #16161d;
        --color-sidebar-text: #dcd7ba;
        --color-sidebar-muted: #727169;
        --color-accent: #7e9cd8;
        --color-link: #7e9cd8;
        --color-link-hover: #7fb4ca;
        --color-text: #dcd7ba;
        --color-heading: #e6c384;
        --color-border: #2d4f67;
        --color-card-bg: rgba(34, 50, 73, 0.3);
        --color-body: #c8c093;
      }

      /* ═══════════════════════════════════════════════════════
               Multi-palette theme system  —  UNDER CONSTRUCTION

               Dark:  Wave (default), One Dark, Gruvbox
               Light: Ayu Light (default), One Light, Gruvbox Light

               Enabling: un-comment the blocks below, activate the
               anti-FOUC <script> above, and wire up the sidebar
               theme toggle UI.
               ═══════════════════════════════════════════════════ */

      /*
            [data-theme-mode="dark"][data-theme-palette="onedark"] { ... One Dark palette ... }
            [data-theme-mode="dark"][data-theme-palette="gruvbox"] { ... Gruvbox Dark palette ... }
            [data-theme-mode="light"][data-theme-palette="ayu"] { ... Ayu Light palette ... }
            [data-theme-mode="light"][data-theme-palette="onelight"] { ... One Light palette ... }
            [data-theme-mode="light"][data-theme-palette="gruvbox-light"] { ... Gruvbox Light palette ... }
            */

      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      /* Custom Scrollbar */
      ::-webkit-scrollbar {
        width: 10px;
      }
      ::-webkit-scrollbar-track {
        background: var(--color-bg);
      }
      ::-webkit-scrollbar-thumb {
