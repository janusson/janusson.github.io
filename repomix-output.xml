// LodSandbox.astro
---

<div
    class="lod-container bg-slate-900 text-slate-100 p-6 rounded-xl border border-slate-800 max-w-2xl my-4"
>
    <div class="flex flex-col md:flex-row gap-6">
        <div class="flex flex-col gap-4 w-full md:w-1/3">
            <div>
                <label
                    class="block text-xs font-mono uppercase tracking-wider text-slate-400 mb-1"
                >
                    Base Noise ($\sigma$): <span id="noise-val">20</span>
                </label>
                <input
                    type="range"
                    id="noise-slider"
                    min="10"
                    max="50"
                    value="20"
                    class="w-full accent-emerald-500"
                />
            </div>

            <div>
                <label
                    class="block text-xs font-mono uppercase tracking-wider text-slate-400 mb-1"
                >
                    Sensitivity ($m$): <span id="slope-val">6</span>
                </label>
                <input
                    type="range"
                    id="slope-slider"
                    min="2"
                    max="12"
                    value="6"
                    class="w-full accent-emerald-500"
                />
            </div>

            <div
                class="flex items-center gap-2 mt-2 bg-slate-950 p-2 rounded border border-slate-800"
            >
                <input
                    type="checkbox"
                    id="avg-checkbox"
                    class="w-4 h-4 rounded border-slate-700 bg-slate-800 text-emerald-500 accent-emerald-500 cursor-pointer"
                />
                <label
                    for="avg-checkbox"
                    class="text-xs font-mono uppercase tracking-wider text-slate-300 cursor-pointer select-none"
                >
                    Signal Averaging (n=4)
                </label>
            </div>

            <div
                class="mt-4 pt-4 border-t border-slate-800 font-mono text-xs flex flex-col gap-2"
            >
                <div class="text-slate-400">
                    Effective $\sigma$: <span id="effective-noise-val"
                        >20.0</span>
                </div>
                <div class="text-amber-400">
                    LOD: <span id="lod-result">11.00</span> ppm
                </div>
                <div class="text-cyan-400">
                    LOQ: <span id="loq-result">33.33</span> ppm
                </div>
            </div>
        </div>

        <div
            class="w-full md:w-2/3 bg-slate-950 p-2 rounded-lg border border-slate-800"
        >
            <svg viewBox="0 0 400 300" class="w-full h-auto overflow-visible">
                <line
                    x1="40"
                    y1="260"
                    x2="380"
                    y2="260"
                    stroke="#334155"
                    stroke-width="1"></line>
                <line
                    x1="40"
                    y1="20"
                    x2="40"
                    y2="260"
                    stroke="#334155"
                    stroke-width="1"></line>

                <rect
                    id="noise-floor"
                    x="40"
                    y="220"
                    width="340"
                    height="40"
                    fill="#f43f5e"
                    fill-opacity="0.1"
                    stroke="#f43f5e"
                    stroke-opacity="0.2"
                    stroke-dasharray="2"></rect>

                <line
                    id="cal-line"
                    x1="40"
                    y1="240"
                    x2="380"
                    y2="60"
                    stroke="#059669"
                    stroke-width="3"></line>

                <line
                    id="lod-line"
                    x1="40"
                    y1="260"
                    x2="40"
                    y2="20"
                    stroke="#fbbf24"
                    stroke-width="1.5"
                    stroke-dasharray="4"></line>
                <line
                    id="loq-line"
                    x1="40"
                    y1="260"
                    x2="40"
                    y2="20"
                    stroke="#22d3ee"
                    stroke-width="1.5"
                    stroke-dasharray="4"></line>

                <text
                    x="380"
                    y="280"
                    fill="#94a3b8"
                    font-size="10"
                    font-family="monospace"
                    text-anchor="end">Concentration →</text
                >
                <text
                    x="20"
                    y="30"
                    fill="#94a3b8"
                    font-size="10"
                    font-family="monospace"
                    transform="rotate(-90 20 30)"
                    text-anchor="end">Signal (AU) →</text
                >
            </svg>
        </div>
    </div>
</div>

<script>
    function initLodSandbox() {
        const noiseSlider = document.getElementById(
            "noise-slider",
        ) as HTMLInputElement;
        const slopeSlider = document.getElementById(
            "slope-slider",
        ) as HTMLInputElement;
        const avgCheckbox = document.getElementById(
            "avg-checkbox",
        ) as HTMLInputElement;

        const noiseVal = document.getElementById("noise-val");
        const effectiveNoiseVal = document.getElementById(
            "effective-noise-val",
        );
        const slopeVal = document.getElementById("slope-val");
        const lodResult = document.getElementById("lod-result");
        const loqResult = document.getElementById("loq-result");

        const calLine = document.getElementById("cal-line");
        const noiseFloor = document.getElementById("noise-floor");
        const lodLine = document.getElementById("lod-line");
        const loqLine = document.getElementById("loq-line");

        const viewWidth = 340;
        const paddingLeft = 40;
        const paddingBottom = 260;

        function updatePlot() {
            const baseSigma = parseFloat(noiseSlider.value);
            const m = parseFloat(slopeSlider.value);

            // Calculate effective noise based on sqrt(n) reduction where n=4
            const sigma = avgCheckbox?.checked ? baseSigma / 2 : baseSigma;

            // Update control readouts
            if (noiseVal) noiseVal.textContent = baseSigma.toString();
            if (effectiveNoiseVal)
                effectiveNoiseVal.textContent = sigma.toFixed(1);
            if (slopeVal) slopeVal.textContent = m.toString();

            // Math transformations
            const lod = (3.3 * sigma) / m;
            const loq = (10 * sigma) / m;

            if (lodResult) lodResult.textContent = lod.toFixed(2);
            if (loqResult) loqResult.textContent = loq.toFixed(2);

            // 1. Update Noise Floor Rect
            const noiseHeightPixels = sigma * 2;
            noiseFloor?.setAttribute(
                "y",
                (paddingBottom - noiseHeightPixels).toString(),
            );
            noiseFloor?.setAttribute("height", noiseHeightPixels.toString());

            // 2. Update Calibration Line
            const y1 = paddingBottom - 20;
            const y2 = paddingBottom - (20 + viewWidth * (m / 15));
            calLine?.setAttribute("y1", y1.toString());
            calLine?.setAttribute("y2", y2.toString());

            // 3. Update Threshold Lines (Assume X-axis limits represent 100 ppm max)
            const lodX = paddingLeft + lod * (viewWidth / 100);
            const loqX = paddingLeft + loq * (viewWidth / 100);

            const clampedLodX = Math.min(Math.max(lodX, paddingLeft), 380);
            const clampedLoqX = Math.min(Math.max(loqX, paddingLeft), 380);

            lodLine?.setAttribute("x1", clampedLodX.toString());
            lodLine?.setAttribute("x2", clampedLodX.toString());
            loqLine?.setAttribute("x1", clampedLoqX.toString());
            loqLine?.setAttribute("x2", clampedLoqX.toString());
        }

        noiseSlider?.addEventListener("input", updatePlot);
        slopeSlider?.addEventListener("input", updatePlot);
        avgCheckbox?.addEventListener("change", updatePlot);

        updatePlot();
    }

    initLodSandbox();
    document.addEventListener("astro:page-load", initLodSandbox);
</script>
</file>

