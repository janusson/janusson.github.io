            }

            .main-content {
                flex: 1;
                margin-left: var(--sidebar-width);
                padding: 3rem 4rem;
                max-width: 900px;
                width: 100%;
            }

            /* Buttons with Cyberpunk/Flashy touch */
            .btn {
                display: inline-block;
                padding: 0.6em 1.4em;
                border-radius: 6px;
                font-weight: 600;
                font-size: 0.95rem;
                transition: all 0.3s ease;
