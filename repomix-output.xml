// SammSpeciationExplorer.astro
// Interactive 2D Drift Time Matrix Spectrometry (DTMS) chart
// Demonstrates TWIMS charge-state separation of polyoxomolybdate speciation.
// Uses D3.js for rendering — already an npm dependency.
---

<div
  id="samm-speciation-explorer"
  class="samm-container bg-kanagawa-bg text-kanagawa-text p-4 sm:p-6 rounded-xl border border-kanagawa-wave my-6 w-full max-w-none"
>
  <!-- ═══ Header ═══ -->
  <h3 class="text-lg font-semibold text-kanagawa-gold mb-1">
    2D Drift Time Matrix Spectrometry — Polyoxomolybdate Speciation
  </h3>
  <p class="text-xs font-mono text-kanagawa-muted mb-4">
    Travelling Wave Ion Mobility Spectrometry (TWIMS) | m/z vs Drift&nbsp;Time&nbsp;(t<sub>D</sub>)
  </p>

  <!-- ═══ Controls ═══ -->
  <div class="samm-controls flex flex-wrap items-center gap-3 sm:gap-4 mb-4 text-xs font-mono">
    <!-- Filter checkboxes -->
    <label class="samm-filter-label inline-flex items-center gap-1.5 cursor-pointer select-none">
      <input type="checkbox" class="samm-filter" data-band="monoanion" checked />
      <span class="text-kanagawa-gold">Monoanions (−1)</span>
    </label>
    <label class="samm-filter-label inline-flex items-center gap-1.5 cursor-pointer select-none">
      <input type="checkbox" class="samm-filter" data-band="dianion" checked />
      <span class="text-kanagawa-accent">Dianions (−2)</span>
    </label>
    <label class="samm-filter-label inline-flex items-center gap-1.5 cursor-pointer select-none">
      <input type="checkbox" class="samm-filter" data-band="solvate" checked />
      <span class="text-teal-400">Deuterated Solvates</span>
    </label>
    <label class="samm-filter-label inline-flex items-center gap-1.5 cursor-pointer select-none">
      <input type="checkbox" class="samm-filter" data-band="artifact" checked />
      <span class="text-red-400">Borosilicate Artifact</span>
    </label>

    <!-- Stepper slider -->
    <div class="samm-stepper ml-auto flex items-center gap-2">
      <label for="samm-nuclearity" class="text-kanagawa-muted whitespace-nowrap">
        Nucleation Step:
      </label>
      <input
        type="range"
        id="samm-nuclearity"
        min="1"
        max="12"
        value="12"
        class="w-24 sm:w-32 accent-kanagawa-gold"
      />
      <span id="samm-step-label" class="text-kanagawa-gold tabular-nums w-10 text-right"
        >Mo<sub>12</sub></span
      >
    </div>
  </div>

  <!-- ═══ Chart container ═══ -->
  <div
    id="samm-chart"
    class="samm-chart bg-kanagawa-sidebar rounded-lg border border-kanagawa-wave overflow-hidden"
  >
    <svg id="samm-svg"></svg>
  </div>

  <!-- ═══ Inspection Card ═══ -->
  <div
    id="samm-inspect"
    class="samm-inspect mt-4 p-4 rounded-lg border border-kanagawa-wave bg-kanagawa-sidebar text-xs font-mono hidden"
  >
    <div id="samm-inspect-content" class="grid grid-cols-2 sm:grid-cols-3 gap-x-4 gap-y-1.5"></div>
  </div>
</div>

<style>
  .samm-filter-label span,
  .samm-filter-label input {
    transition: opacity 0.2s ease;
  }
  .samm-filter-label:has(input:not(:checked)) span {
    opacity: 0.45;
  }
  .samm-chart {
    position: relative;
    width: 100%;
    min-height: 420px;
  }
