            /* Floating Blog Post Cards */
            .post-card {
                padding: 1.5em;
                background: var(--color-card-bg);
                border: 1px solid var(--color-border);
                border-radius: 8px;
                transition:
                    transform 0.2s ease,
                    box-shadow 0.2s ease,
                    border-color 0.2s ease;
                margin-bottom: 1.5em;
            }

            .post-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 10px 25px rgba(0, 0, 0, 0.4);
                border-color: var(--color-accent);
            }

            .post-card h2 {
                margin-top: 0;
                border-bottom: none;
                padding-bottom: 0;
                font-size: 1.4rem;
            }

            .post-card h2 a {
                color: var(--color-accent);
            }

            .post-card h2 a:hover {
                text-shadow: none;
            }

            .post-meta {
                font-size: 0.85rem;
                color: var(--color-sidebar-muted);
                margin-bottom: 0.8em;
                font-family: var(--font-mono);
            }

            .post-tags {
                margin-top: 0.8em;
                display: flex;
                flex-wrap: wrap;
                gap: 0.5em;
            }

            .post-tag {
                display: inline-block;
                background: rgba(126, 156, 216, 0.1);
                color: var(--color-accent);
                border: 1px solid var(--color-border);
                padding: 0.2em 0.8em;
                border-radius: 20px;
                font-size: 0.8rem;
                font-weight: 500;
                transition: all 0.2s ease;
            }

            .post-tag:hover {
                background: var(--color-accent);
                color: var(--color-bg);
            }

            /* Mermaid diagrams */
            .mermaid-container {
                margin: 2em 0;
                overflow-x: auto;
                display: flex;
                justify-content: center;
            }

            .mermaid-container svg {
                max-width: 100%;
                height: auto;
                border-radius: 8px;
            }

            @media (max-width: 768px) {
                body {
                    flex-direction: column;
                }
                .main-content {
                    margin-left: 0;
                    padding: 2rem 1.5rem;
                }
            }
        </style>
    </head>
    <body>
        <!-- Mastodon domain verification - hidden -->
        <a rel="me" href="https://mastodon.social/@janussone" hidden>Mastodon</a
        >
        <div class="page-wrapper">
            <Sidebar />
            <main class="main-content">
                <slot />
            </main>
        </div>

        <!-- Mermaid diagram rendering -->
        <script type="module">
            import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs";
            mermaid.initialize({
                startOnLoad: false,
                theme: "dark",
                securityLevel: "loose",
            });

            async function renderMermaidDiagrams() {
                const blocks = document.querySelectorAll(
                    'pre[data-language="mermaid"]',
                );
                for (const pre of blocks) {
                    if (pre.hasAttribute("data-mermaid-rendered")) continue;
                    pre.setAttribute("data-mermaid-rendered", "true");
                    const id =
                        "mermaid-" + Math.random().toString(36).substring(2, 9);
                    try {
                        const { svg } = await mermaid.render(
                            id,
                            pre.textContent || "",
                        );
                        const container = document.createElement("div");
                        container.className = "mermaid-container";
                        container.innerHTML = svg;
                        pre.replaceWith(container);
                    } catch (err) {
                        console.error("Mermaid render failed:", err);
                    }
                }
            }

            renderMermaidDiagrams();
        </script>
    </body>
</html>
</file>

<file path="src/pages/posts.astro">
---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
const sortedPosts = posts.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

// Extract all unique tags from the blog collection
const allTags = Array.from(
  new Set(sortedPosts.flatMap((post) => post.data.tags))
).sort();
---

<BaseLayout
  title="Posts"
  description="Technical posts on scientific software, analytical chemistry, quantitative finance, and signal processing by Dr. Eric Janusson."
>
  <h1>Posts</h1>
  <p style="color: var(--color-sidebar-muted); margin-bottom: 2em;">
    Deep dives into LC-MS workflows, laboratory automation, data analytics,
    quantitative finance, audio signal processing, and open-source scientific
    tooling.
  </p>

  <!-- Tag Filter UI -->
  {
    allTags.length > 0 && (
      <div id="tag-filters" style="margin-bottom: 2em;">
        <button
          class="post-tag tag-filter-btn tag-filter-btn--active"
          data-tag="all"
          style="margin-right: 0.5em; margin-bottom: 0.5em; cursor: pointer;"
        >
          All
        </button>
        {allTags.map((tag) => (
          <button
            class="post-tag tag-filter-btn"
            data-tag={tag}
            style="margin-right: 0.5em; margin-bottom: 0.5em; cursor: pointer;"
          >
            {tag}
          </button>
        ))}
      </div>
    )
  }

  <!-- Post List -->
  <div id="post-list">
    {
      sortedPosts.map((post) => (
        <article
          class="post-card"
          data-tags={post.data.tags.join(",")}
        >
          <h2>
            <a href={`/blog/${post.id}/`}>{post.data.title}</a>
          </h2>
          <p class="post-meta">
            {post.data.date.toLocaleDateString("en-CA", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </p>
          {post.data.description && <p>{post.data.description}</p>}
          {
            post.data.tags.length > 0 && (
              <div class="post-tags">
                {post.data.tags.map((tag) => (
                  <span class="post-tag">{tag}</span>
                ))}
              </div>
            )
          }
        </article>
      ))
    }
  </div>
</BaseLayout>

<script>
  // Vanilla JS tag filtering
  document.addEventListener("DOMContentLoaded", () => {
    const filterButtons = document.querySelectorAll(".tag-filter-btn");
    const postCards = document.querySelectorAll("#post-list .post-card");

    function setActiveButton(activeBtn: Element) {
      filterButtons.forEach((btn) => btn.classList.remove("tag-filter-btn--active"));
      activeBtn.classList.add("tag-filter-btn--active");
    }

    filterButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const selectedTag = btn.getAttribute("data-tag");
        setActiveButton(btn);

        postCards.forEach((card) => {
          const cardTags = (card.getAttribute("data-tags") ?? "").split(",");
          if (selectedTag === "all" || cardTags.includes(selectedTag ?? "")) {
            (card as HTMLElement).style.display = "";
          } else {
            (card as HTMLElement).style.display = "none";
          }
        });
      });
    });

    // Add styles for the active tag button
    const style = document.createElement("style");
    style.textContent = `
      .tag-filter-btn--active {
        background: var(--color-accent) !important;
        color: var(--color-bg) !important;
      }
    `;
    document.head.appendChild(style);
  });
</script>
</file>

