                color: var(--color-accent);
                border: 1px solid var(--color-border);
                padding: 0.2em 0.8em;
                border-radius: 20px;
                font-size: 0.8rem;
                font-weight: 500;
                transition: all 0.2s ease;
            }

            .post-tag:hover {
                background: var(--color-accent);
                color: var(--color-bg);
            }

            /* Mermaid diagrams */
            .mermaid-container {
                margin: 2em 0;
                overflow-x: auto;
                display: flex;
                justify-content: center;
            }

            .mermaid-container svg {
                max-width: 100%;
                height: auto;
                border-radius: 8px;
            }

            @media (max-width: 768px) {
