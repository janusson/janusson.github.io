---
const navItems = [
    { label: "Home", href: "/" },
    { label: "Posts", href: "/posts/" },
    { label: "Projects", href: "/projects/" },
    { label: "Publications", href: "/publications/" },
    { label: "About", href: "/about/" },
    { label: "CV", href: "/cv/" },
    { label: "Contact", href: "/contact/" },
];

const socialLinks = [
    {
        label: "GitHub",
        icon: "fa-brands fa-github",
        url: "https://github.com/janusson",
    },
    {
        label: "Google Scholar",
        icon: "fa-solid fa-graduation-cap",
        url: "https://scholar.google.com/citations?user=PaUrfcQAAAAJ&hl=en",
    },
    {
        label: "ORCiD",
        icon: "fa-brands fa-orcid",
        url: "https://orcid.org/0000-0002-3207-7067",
    },
    {
        label: "Mastodon",
        icon: "fa-brands fa-mastodon",
        url: "https://mastodon.social/@janussone",
        rel: "me noopener noreferrer",
    },
];

const currentPath = Astro.url?.pathname ?? "/";
---

<aside class="sidebar">
    <!-- ═══ Mobile header bar (hidden on desktop) ═══ -->
    <div class="sidebar-mobile-bar">
        <a href="/" class="sidebar-mobile-identity">
            <img
                src="/assets/images/avatar.webp"
                alt="Dr. Eric Janusson"
                class="sidebar-mobile-avatar"
                width="40"
                height="40"
            />
            <span class="sidebar-mobile-name">Dr. Eric Janusson</span>
        </a>

        <button
            class="sidebar-menu-toggle"
            aria-expanded="false"
            aria-controls="sidebar-drawer"
            aria-label="Toggle navigation menu"
            type="button"
        >
            <span class="hamburger-box">
                <span class="hamburger-inner"></span>
            </span>
        </button>
    </div>

    <!-- ═══ Drawer (collapsible on mobile, always visible on desktop) ═══ -->
    <div id="sidebar-drawer" class="sidebar-drawer">
        <div class="sidebar-inner">
            <!-- Avatar & Identity -->
            <a href="/" class="sidebar-identity">
                <img
                    src="/assets/images/avatar.webp"
                    alt="Dr. Eric Janusson"
                    class="sidebar-avatar"
                    width="100"
                    height="100"
                />
                <span class="sidebar-name">Dr. Eric Janusson</span>
            </a>

            <p class="sidebar-bio">
                Analytical chemist developing tools for mass spectrometry
                analytics and optimization problems.
            </p>

            <!-- Navigation -->
            <nav class="sidebar-nav" aria-label="Main navigation">
                <ul>
                    {
                        navItems.map((item) => (
                            <li>
                                <a
                                    href={item.href}
                                    class:list={[
                                        "sidebar-nav-link",
                                        {
                                            "sidebar-nav-link--active":
                                                currentPath === item.href,
                                        },
                                    ]}
                                >
                                    {item.label}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </nav>

            <!-- Social Links -->
            <div class="sidebar-social">
                {
                    socialLinks.map((link) => (
                        <a
                            href={link.url}
                            class="sidebar-social-link"
                            target="_blank"
                            rel={link.rel ?? "noopener noreferrer"}
                            aria-label={link.label}
                            title={link.label}
                        >
                            <i class={link.icon} />
                        </a>
                    ))
                }
            </div>

            <!-- Theme switcher UNDER CONSTRUCTION — see BaseLayout for palette blocks -->

            <p class="sidebar-footer">
                &copy; {new Date().getFullYear()} Dr. Eric Janusson
            </p>
        </div>
    </div>
</aside>

<style>
    /* ═══════════════════════════════════════════════
       Desktop sidebar (unchanged)
       ═══════════════════════════════════════════════ */

    .sidebar {
        position: fixed;
        top: 0;
        left: 0;
        width: var(--sidebar-width);
        height: 100vh;
        background: var(--color-sidebar);
        color: var(--color-sidebar-text);
        overflow-y: auto;
        z-index: 100;
        display: flex;
        flex-direction: column;
        border-right: 1px solid rgba(45, 79, 103, 0.4);
    }

    .sidebar-inner {
        display: flex;
        flex-direction: column;
        padding: 2rem 1.5rem;
        height: 100%;
    }

    .sidebar-identity {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-decoration: none;
        color: inherit;
        margin-bottom: 1.25rem;
        transition: opacity 0.2s ease;
    }

    .sidebar-identity:hover {
        opacity: 0.85;
    }

    .sidebar-avatar {
        width: 90px;
        height: 90px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid var(--color-accent);
        margin-bottom: 0.75rem;
        transition: box-shadow 0.3s ease;
    }

    .sidebar-avatar:hover {
        box-shadow: 0 0 20px rgba(126, 156, 216, 0.5);
    }

    .sidebar-name {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--color-heading);
        text-align: center;
        line-height: 1.3;
    }

    .sidebar-bio {
        font-size: 0.8rem;
        color: var(--color-sidebar-muted);
        text-align: center;
        line-height: 1.5;
        margin-bottom: 1.5rem;
    }

    .sidebar-nav {
        flex: 1;
    }

    .sidebar-nav ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .sidebar-nav li {
        margin-bottom: 0.15rem;
    }

    .sidebar-nav-link {
        display: block;
        padding: 0.5rem 0.75rem;
        border-radius: 6px;
        color: var(--color-sidebar-muted);
        font-size: 0.9rem;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.2s ease;
        position: relative;
    }

    .sidebar-nav-link:hover {
        background: rgba(126, 156, 216, 0.1);
        color: var(--color-sidebar-text);
        text-decoration: none;
        transform: translateX(4px);
    }

    .sidebar-nav-link--active {
        background: rgba(126, 156, 216, 0.15);
        color: var(--color-accent);
        font-weight: 600;
    }

    .sidebar-nav-link--active::before {
        content: "";
        position: absolute;
        left: 0;
        top: 50%;
        transform: translateY(-50%);
        width: 3px;
        height: 60%;
        background: var(--color-accent);
        border-radius: 0 2px 2px 0;
    }

    .sidebar-social {
        display: flex;
        justify-content: center;
        gap: 0.75rem;
        margin-top: 1.5rem;
        padding-top: 1.25rem;
        border-top: 1px solid rgba(45, 79, 103, 0.4);
    }

    .sidebar-social-link {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        border-radius: 50%;
        color: var(--color-sidebar-muted);
        font-size: 1rem;
        transition: all 0.2s ease;
        text-decoration: none;
    }

    .sidebar-social-link:hover {
        background: rgba(126, 156, 216, 0.15);
        color: var(--color-accent);
        text-decoration: none;
        box-shadow: 0 0 12px rgba(126, 156, 216, 0.25);
    }

    .sidebar-footer {
        font-size: 0.7rem;
        color: rgba(220, 215, 186, 0.2);
        text-align: center;
        margin-top: 1rem;
    }

    /* ── Theme controls (UNDER CONSTRUCTION) ── */
    /*
    .sidebar-theme { ... }
    .sidebar-theme-icon { ... }
    .sidebar-theme-palette { ... }
    .sidebar-theme-mode { ... }
    */

    /* ── Mobile bar & drawer: hidden on desktop ── */
    .sidebar-mobile-bar {
        display: none;
    }

    .sidebar-drawer {
        /* On desktop the drawer wrapper is transparent —
           content inside .sidebar-inner flows normally */
    }

    /* ═══════════════════════════════════════════════
       Mobile (≤ 768px)
       ═══════════════════════════════════════════════ */

    @media (max-width: 768px) {
        .sidebar {
            position: relative;
            width: 100%;
            height: auto;
            overflow-y: visible;
            border-right: none;
            border-bottom: 1px solid rgba(45, 79, 103, 0.4);
        }

        /* ── Mobile header bar ── */
        .sidebar-mobile-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.75rem 1rem;
            background: var(--color-sidebar);
        }

        .sidebar-mobile-identity {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            text-decoration: none;
            color: inherit;
            min-width: 0;
        }

        .sidebar-mobile-identity:hover {
            opacity: 0.85;
        }

        .sidebar-mobile-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid var(--color-accent);
            flex-shrink: 0;
        }

        .sidebar-mobile-name {
            font-size: 0.95rem;
            font-weight: 700;
            color: var(--color-heading);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        /* ── Hamburger toggle ── */
        .sidebar-menu-toggle {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 44px;
            height: 44px;
            padding: 0;
            margin: 0;
            background: transparent;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            color: var(--color-sidebar-muted);
            flex-shrink: 0;
            transition:
                background 0.2s ease,
                color 0.2s ease;
            -webkit-tap-highlight-color: transparent;
        }

        .sidebar-menu-toggle:hover {
            background: rgba(126, 156, 216, 0.1);
            color: var(--color-accent);
        }

        .sidebar-menu-toggle:focus-visible {
            outline: 2px solid var(--color-accent);
            outline-offset: 2px;
        }

        /* Hamburger icon box */
        .hamburger-box {
            position: relative;
            display: block;
            width: 22px;
            height: 16px;
        }

        .hamburger-inner {
            position: absolute;
            top: 50%;
            left: 0;
            width: 100%;
            height: 2px;
            background: currentColor;
            border-radius: 2px;
            transition:
                transform 0.25s ease,
                background 0.15s ease;
            transform: translateY(-50%);
        }

        .hamburger-inner::before,
        .hamburger-inner::after {
            content: "";
            position: absolute;
            left: 0;
            width: 100%;
            height: 2px;
            background: currentColor;
            border-radius: 2px;
            transition: transform 0.25s ease;
        }

        .hamburger-inner::before {
            top: -6px;
        }

        .hamburger-inner::after {
            top: 6px;
        }

        /* Open state — animated to ✕ */
        .sidebar-menu-toggle[aria-expanded="true"] .hamburger-inner {
            background: transparent;
        }

        .sidebar-menu-toggle[aria-expanded="true"] .hamburger-inner::before {
            transform: translateY(6px) rotate(45deg);
        }

        .sidebar-menu-toggle[aria-expanded="true"] .hamburger-inner::after {
            transform: translateY(-6px) rotate(-45deg);
        }

        /* ── Collapsible drawer ── */
        .sidebar-drawer {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .sidebar-drawer.open {
            max-height: 700px;
            overflow-y: auto;
        }

        /* ── Drawer contents ── */
        .sidebar-inner {
            padding: 0 0 1.25rem;
            height: auto;
        }

        .sidebar-identity {
            display: none;
        }

        .sidebar-bio {
            display: block;
            font-size: 0.85rem;
            text-align: left;
            padding: 0.75rem 1rem 1rem;
            margin-bottom: 0;
            border-bottom: 1px solid rgba(45, 79, 103, 0.25);
        }

        /* ── Navigation: vertical, touch-friendly ── */
        .sidebar-nav {
            flex: none;
        }

        .sidebar-nav ul {
            display: flex;
            flex-direction: column;
            gap: 0;
        }

        .sidebar-nav li {
            margin-bottom: 0;
            border-bottom: 1px solid rgba(45, 79, 103, 0.15);
        }

        .sidebar-nav-link {
            font-size: 1rem;
            font-weight: 500;
            padding: 0 1rem;
            min-height: 48px;
            display: flex;
            align-items: center;
            border-radius: 0;
            border-left: 3px solid transparent;
            transition:
                background 0.2s ease,
                color 0.2s ease,
                border-color 0.2s ease;
        }

        .sidebar-nav-link:hover {
            background: rgba(126, 156, 216, 0.1);
            color: var(--color-sidebar-text);
            border-left-color: var(--color-accent);
            transform: none;
        }

        .sidebar-nav-link--active {
            background: rgba(126, 156, 216, 0.12);
            color: var(--color-accent);
            border-left-color: var(--color-accent);
            font-weight: 600;
        }

        .sidebar-nav-link--active::before {
            display: none;
        }

        /* ── Social links ── */
        .sidebar-social {
            justify-content: flex-start;
            gap: 0.5rem;
            margin-top: 0.75rem;
            padding: 0.75rem 1rem;
            border-top: none;
        }

        .sidebar-social-link {
            width: 40px;
            height: 40px;
            font-size: 1.1rem;
        }

        /* ── Footer ── */
        .sidebar-footer {
            text-align: left;
            padding: 0 1rem 0.5rem;
            margin-top: 0.25rem;
            font-size: 0.7rem;
        }

        /* ── Theme toggle (UNDER CONSTRUCTION) ── */
        /*
        .sidebar-theme {
            padding: 0.25rem 1rem 0.75rem;
            margin-top: 0;
            border-top: none;
            justify-content: flex-start;
            gap: 0.5rem;
        }
        */
    }
</style>

<script>
    // ── Mobile hamburger-menu toggle (vanilla JS, zero dependencies) ──

    const drawer = document.getElementById("sidebar-drawer");
    const toggle = document.querySelector(".sidebar-menu-toggle");
    if (!drawer || !toggle) {
        // Component not present on this page — nothing to do.
    } else {
        const mobileMQ = window.matchMedia("(max-width: 768px)");

        function openMenu(): void {
            drawer!.style.maxHeight = drawer!.scrollHeight + "px";
            drawer!.classList.add("open");
            toggle!.setAttribute("aria-expanded", "true");
        }

        function closeMenu(): void {
            drawer!.style.maxHeight = drawer!.scrollHeight + "px";
            requestAnimationFrame(() => {
                requestAnimationFrame(() => {
                    drawer!.style.maxHeight = "0";
                });
            });
            drawer!.classList.remove("open");
            toggle!.setAttribute("aria-expanded", "false");
        }

        function isOpen(): boolean {
            return drawer!.classList.contains("open");
        }

        // ── Toggle click ──
        toggle.addEventListener("click", () => {
            if (isOpen()) {
                closeMenu();
            } else {
                openMenu();
            }
        });

        // ── Close on Escape ──
        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && isOpen()) {
                closeMenu();
                (toggle as HTMLElement).focus();
            }
        });

        // ── Close when a nav link is tapped (mobile navigation) ──
        drawer.querySelectorAll(".sidebar-nav-link").forEach((link) => {
            link.addEventListener("click", () => {
                if (mobileMQ.matches && isOpen()) {
                    closeMenu();
                }
            });
        });

        // ── Collapse drawer if the viewport expands past 768 px ──
        mobileMQ.addEventListener("change", (e) => {
            if (!e.matches) {
                drawer!.style.maxHeight = "";
                drawer!.classList.remove("open");
                toggle!.setAttribute("aria-expanded", "false");
            }
        });
    }

    /*
     * Theme controls (palette cycle + dark/light toggle)
     * UNDER CONSTRUCTION  —  re-enable when multi-palette CSS
     * is un-commented in BaseLayout.astro.
     *
    var paletteBtn = document.getElementById("theme-palette-btn");
    ...
    */
</script>
</file>

