      }

      body {
        font-family: var(--font-sans);
        background: var(--color-bg);
        color: var(--color-text);
        line-height: 1.7;
        display: flex;
        min-height: 100vh;
      }

      a {
        color: var(--color-link);
        text-decoration: none;
        transition:
          color 0.2s ease,
          text-shadow 0.2s ease;
      }

      a:hover {
        color: var(--color-link-hover);
        text-shadow: 0 0 8px rgba(126, 156, 216, 0.4);
      }

      h1,
      h2,
      h3,
      h4,
      h5,
      h6 {
        color: var(--color-heading);
        font-weight: 700;
        line-height: 1.3;
        margin-top: 1.5em;
        margin-bottom: 0.5em;
        letter-spacing: -0.02em;
      }

      h1 {
        font-size: 2.2rem;
        margin-top: 0;
      }
      h2 {
        font-size: 1.6rem;
        border-bottom: 1px solid var(--color-border);
        padding-bottom: 0.3em;
      }
      h3 {
        font-size: 1.3rem;
      }

      p {
        margin-bottom: 1em;
        color: var(--color-body);
      }

      ul,
      ol {
        margin-bottom: 1em;
        padding-left: 1.5em;
        color: var(--color-body);
      }
      li {
        margin-bottom: 0.4em;
      }

      blockquote {
        border-left: 4px solid var(--color-accent);
        padding: 0.8em 1.2em;
        margin: 1.5em 0;
        color: var(--color-body);
        background: var(--color-card-bg);
