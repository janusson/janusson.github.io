      calcMz: 592.75,
      expMz: 592.04,
      driftTime: 4.07,
      note: "Tetrameric intermediate",
      band: "monoanion",
      nuclearity: 4,
    },
    {
      id: "Mo5",
      formula: "[HMo\u2085O\u2081\u2086]\u207B",
      calcMz: 736.69,
      expMz: 736.76,
      driftTime: 4.4,
      note: "Pentameric intermediate",
