    },
    {
      id: "Mo6",
      formula: "[HMo\u2086O\u2081\u2089]\u207B",
      calcMz: 880.62,
      expMz: 879.5,
      driftTime: 4.84,
      note: "Lindqvist cluster precursor core",
      band: "monoanion",
      nuclearity: 6,
    },
    {
      id: "Mo7",
      formula: "[HMo\u2087O\u2082\u2082]\u207B",
      calcMz: 1024.56,
      expMz: 1023.24,
      driftTime: 5.39,
      note: "Heptameric assembly",
      band: "monoanion",
      nuclearity: 7,
    },
    {
      id: "Mo8",
      formula: "[HMo\u2088O\u2082\u2085]\u207B",
      calcMz: 1168.49,
      expMz: 1167.98,
      driftTime: 6.27,
      note: "Octameric assembly",
      band: "monoanion",
      nuclearity: 8,
    },
    {
      id: "Mo9",
      formula: "[HMo\u2089O\u2082\u2088]\u207B",
      calcMz: 1312.43,
      expMz: 1310.78,
      driftTime: 6.93,
      note: "Nonameric assembly",
      band: "monoanion",
      nuclearity: 9,
    },
    {
      id: "Mo10",
      formula: "[HMo\u2081\u2080O\u2083\u2081]\u207B",
      calcMz: 1456.37,
      expMz: 1449.05,
      driftTime: 7.81,
      note: "Decameric assembly",
      band: "monoanion",
      nuclearity: 10,
    },
    {
      id: "Mo11",
