---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
const sortedPosts = posts.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<BaseLayout
  title="Posts"
  description="Technical posts on analytical chemistry, mass spectrometry, and scientific programming by Dr. Eric Janusson."
>
  <h1>Posts</h1>
  <p style="color: var(--color-sidebar-muted); margin-bottom: 2em;">
    Deep dives into LC-MS workflows, laboratory automation, data analytics, and
    open-source scientific tooling.
  </p>

  {
    sortedPosts.map((post) => (
      <article class="post-card">
        <h2>
          <a href={`/blog/${post.id}/`}>{post.data.title}</a>
        </h2>
        <p class="post-meta">
          {post.data.date.toLocaleDateString("en-CA", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </p>
        {post.data.description && <p>{post.data.description}</p>}
        {
          post.data.tags.length > 0 && (
            <div class="post-tags">
              {post.data.tags.map((tag) => (
                <span class="post-tag">{tag}</span>
              ))}
            </div>
          )
        }
      </article>
    ))
  }
</BaseLayout>
