---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
    const posts = await getCollection("blog");
    return posts.map((post) => ({
        params: { slug: post.id },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description}>
    <article>
        <header class="post-header">
            <h1 data-pagefind-meta="title">{post.data.title}</h1>
            <p class="post-meta" data-pagefind-meta="date">
                {
                    post.data.date.toLocaleDateString("en-CA", {
                        year: "numeric",
                        month: "long",
                        day: "numeric",
                    })
                }
            </p>
            {
                post.data.tags.length > 0 && (
                    <div class="post-tags" data-pagefind-meta="tags">
                        {post.data.tags.map((tag) => (
                            <span class="post-tag">{tag}</span>
                        ))}
                    </div>
                )
            }
        </header>

        <hr />

        <div class="post-body">
            <Content />
        </div>

        <hr />

        <nav class="post-nav" aria-label="Post navigation">
            <a href="/posts/" class="btn btn--primary">&larr; All posts</a>
        </nav>
    </article>
</BaseLayout>

<style>
    .post-header {
        margin-bottom: 1rem;
    }

    .post-body {
        font-size: 1.05rem;
        line-height: 1.8;
    }

    .post-nav {
        margin-top: 2rem;
    }
</style>
