---
import Sidebar from "../components/Sidebar.astro";

interface PageMeta {
  title: string;
  description?: string;
  image?: string;
}

export interface Props extends PageMeta {
  frontmatter?: PageMeta;
}

const DEFAULT_IMAGE = "/assets/images/Spectral-Similarity-Networking-3-Large.png";

const { title, description, image } = Astro.props.frontmatter || Astro.props;
const pageDescription =
  description ||
  "Analytical chemist developing tools for mass spectrometry analytics and optimization problems.";
const resolvedImage = new URL(
  image || DEFAULT_IMAGE,
  Astro.url || Astro.site || "https://www.ericjanusson.ca",
).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />

    <!-- OpenGraph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:image" content={resolvedImage} />
    <meta property="og:image:alt" content={title} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={resolvedImage} />

    <title>{title} | Dr. Eric Janusson</title>

    <!-- ═══════════════════════════════════════════════════════
             Theme switcher  —  UNDER CONSTRUCTION
             Multi-palette (Wave, One Dark, Gruvbox, Ayu Light, …)
             with dark/light mode toggle.
             ═══════════════════════════════════════════════════ -->
    <!--
        <script is:inline>
            (function () {
                var m = localStorage.getItem("theme-mode") || "dark";
                var p = localStorage.getItem("theme-" + m) || "wave";
                document.documentElement.setAttribute("data-theme-mode", m);
                document.documentElement.setAttribute("data-theme-palette", p);
            })();
        </script>
        -->

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <style is:global>
      /* ═══════════════════════════════════════════════════════
               Shared tokens (not theme-dependent)
               ═══════════════════════════════════════════════════ */
      :root {
        --sidebar-width: 280px;
        --font-sans: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        --font-mono: "JetBrains Mono", "Fira Code", monospace;
      }

      /* ═══════════════════════════════════════════════════════
               Kanagawa Wave  —  fixed theme
               ═══════════════════════════════════════════════════ */
      :root {
        --color-bg: #1f1f28;
        --color-sidebar: #16161d;
        --color-sidebar-text: #dcd7ba;
        --color-sidebar-muted: #727169;
        --color-accent: #7e9cd8;
        --color-link: #7e9cd8;
        --color-link-hover: #7fb4ca;
        --color-text: #dcd7ba;
        --color-heading: #e6c384;
        --color-border: #2d4f67;
        --color-card-bg: rgba(34, 50, 73, 0.3);
        --color-body: #c8c093;
      }

      /* ═══════════════════════════════════════════════════════
               Multi-palette theme system  —  UNDER CONSTRUCTION

               Dark:  Wave (default), One Dark, Gruvbox
               Light: Ayu Light (default), One Light, Gruvbox Light

               Enabling: un-comment the blocks below, activate the
               anti-FOUC <script> above, and wire up the sidebar
               theme toggle UI.
               ═══════════════════════════════════════════════════ */

      /*
            [data-theme-mode="dark"][data-theme-palette="onedark"] { ... One Dark palette ... }
            [data-theme-mode="dark"][data-theme-palette="gruvbox"] { ... Gruvbox Dark palette ... }
            [data-theme-mode="light"][data-theme-palette="ayu"] { ... Ayu Light palette ... }
            [data-theme-mode="light"][data-theme-palette="onelight"] { ... One Light palette ... }
            [data-theme-mode="light"][data-theme-palette="gruvbox-light"] { ... Gruvbox Light palette ... }
            */

      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      /* Custom Scrollbar */
      ::-webkit-scrollbar {
        width: 10px;
      }
      ::-webkit-scrollbar-track {
        background: var(--color-bg);
      }
      ::-webkit-scrollbar-thumb {
        background: var(--color-border);
        border-radius: 5px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: var(--color-accent);
      }

      html {
        font-size: 16px;
        scroll-behavior: smooth;
      }

      body {
        font-family: var(--font-sans);
        background: var(--color-bg);
        color: var(--color-text);
        line-height: 1.7;
        display: flex;
        min-height: 100vh;
      }

      a {
        color: var(--color-link);
        text-decoration: none;
        transition:
          color 0.2s ease,
          text-shadow 0.2s ease;
      }

      a:hover {
        color: var(--color-link-hover);
        text-shadow: 0 0 8px rgba(126, 156, 216, 0.4);
      }

      h1,
      h2,
      h3,
      h4,
      h5,
      h6 {
        color: var(--color-heading);
        font-weight: 700;
        line-height: 1.3;
        margin-top: 1.5em;
        margin-bottom: 0.5em;
        letter-spacing: -0.02em;
      }

      h1 {
        font-size: 2.2rem;
        margin-top: 0;
      }
      h2 {
        font-size: 1.6rem;
        border-bottom: 1px solid var(--color-border);
        padding-bottom: 0.3em;
      }
      h3 {
        font-size: 1.3rem;
      }

      p {
        margin-bottom: 1em;
        color: var(--color-body);
      }

      ul,
      ol {
        margin-bottom: 1em;
        padding-left: 1.5em;
        color: var(--color-body);
      }
      li {
        margin-bottom: 0.4em;
      }

      blockquote {
        border-left: 4px solid var(--color-accent);
        padding: 0.8em 1.2em;
        margin: 1.5em 0;
        color: var(--color-body);
        background: var(--color-card-bg);
        border-radius: 0 8px 8px 0;
        font-style: italic;
      }

      code {
        font-family: var(--font-mono);
        font-size: 0.9em;
        background: var(--color-card-bg);
        color: var(--color-heading);
        padding: 0.2em 0.4em;
        border-radius: 4px;
      }

      pre {
        background: var(--color-sidebar);
        border: 1px solid var(--color-border);
        box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.15);
        padding: 1.2em;
        border-radius: 8px;
        overflow-x: auto;
        margin-bottom: 1.5em;
      }

      pre code {
        background: none;
        padding: 0;
        color: var(--color-text);
      }

      table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 1.5em;
        font-size: 0.95rem;
      }

      th,
      td {
        border: 1px solid var(--color-border);
        padding: 0.8em 1em;
        text-align: left;
      }

      th {
        background: var(--color-card-bg);
        color: var(--color-heading);
        font-weight: 600;
      }

      img {
        max-width: 100%;
        height: auto;
        border-radius: 8px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
      }

      hr {
        border: none;
        border-top: 1px solid var(--color-border);
        margin: 2.5em 0;
      }

      /* Layout */
      .page-wrapper {
        display: flex;
        width: 100%;
        min-height: 100vh;
      }

      .main-content {
        flex: 1;
        margin-left: var(--sidebar-width);
        padding: 3rem 4rem;
        max-width: 900px;
        width: 100%;
      }

      /* Buttons */
      .btn {
        display: inline-block;
        padding: 0.6em 1.4em;
        border-radius: 6px;
        font-weight: 600;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        text-decoration: none;
      }

      .btn--primary {
        background: transparent;
        color: var(--color-accent);
        border: 1px solid var(--color-accent);
        box-shadow: 0 0 10px rgba(126, 156, 216, 0.1);
      }

      .btn--primary:hover {
        background: var(--color-accent);
        color: var(--color-bg);
        box-shadow: 0 0 20px rgba(126, 156, 216, 0.4);
        text-decoration: none;
      }

      .btn--large {
        padding: 0.85em 2em;
        font-size: 1rem;
      }

      /* Blog Post Cards */
      .post-card {
        padding: 1.5em;
        background: var(--color-card-bg);
        border: 1px solid var(--color-border);
        border-radius: 8px;
        transition:
          transform 0.2s ease,
          box-shadow 0.2s ease,
          border-color 0.2s ease;
        margin-bottom: 1.5em;
      }

      .post-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.4);
        border-color: var(--color-accent);
      }

      .post-card h2 {
        margin-top: 0;
        border-bottom: none;
        padding-bottom: 0;
        font-size: 1.4rem;
      }

      .post-card h2 a {
        color: var(--color-accent);
      }

      .post-card h2 a:hover {
        text-shadow: none;
      }

      .post-meta {
        font-size: 0.85rem;
        color: var(--color-sidebar-muted);
        margin-bottom: 0.8em;
        font-family: var(--font-mono);
      }

      .post-tags {
        margin-top: 0.8em;
        display: flex;
        flex-wrap: wrap;
        gap: 0.5em;
      }

      .post-tag {
        display: inline-block;
        background: var(--color-card-bg);
        color: var(--color-accent);
        border: 1px solid var(--color-border);
        padding: 0.2em 0.8em;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 500;
        transition: all 0.2s ease;
      }

      .post-tag:hover {
        background: var(--color-accent);
        color: var(--color-bg);
      }

      /* Mermaid diagrams */
      .mermaid-container {
        margin: 2em 0;
        overflow-x: auto;
        display: flex;
        justify-content: center;
      }

      .mermaid-container svg {
        max-width: 100%;
        height: auto;
        border-radius: 8px;
      }

      @media (max-width: 768px) {
        body {
          flex-direction: column;
        }
        .main-content {
          margin-left: 0;
          padding: 2rem 1.5rem;
        }
      }
    </style>
  </head>
  <body>
    <!-- Mastodon domain verification - hidden -->
    <a rel="me" href="https://mastodon.social/@janussone" hidden>Mastodon</a>
    <div class="page-wrapper">
      <Sidebar />
      <main class="main-content">
        <slot />
      </main>
    </div>

    <!-- Mermaid diagram rendering -->
    <script type="module" is:inline>
      import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs";
      mermaid.initialize({
        startOnLoad: false,
        theme: "dark",
        securityLevel: "loose",
      });

      async function renderMermaidDiagrams() {
        const blocks = document.querySelectorAll(
          'pre[data-language="mermaid"], pre:has(code.language-mermaid), pre.mermaid, div.mermaid',
        );
        for (const el of blocks) {
          if (el.hasAttribute("data-mermaid-rendered")) continue;
          el.setAttribute("data-mermaid-rendered", "true");

          // Extract raw diagram text from <code> child if present,
          // otherwise fall back to the element's own textContent.
          const codeEl = el.querySelector("code.language-mermaid");
          const source = codeEl ? codeEl.textContent || "" : el.textContent || "";

          const id = "mermaid-" + Math.random().toString(36).substring(2, 9);
          try {
            const { svg } = await mermaid.render(id, source);
            const container = document.createElement("div");
            container.className = "mermaid-container";
            container.innerHTML = svg;
            el.replaceWith(container);
          } catch (err) {
            console.error("Mermaid render failed:", err);
          }
        }
      }

      renderMermaidDiagrams();
    </script>
  </body>
</html>
